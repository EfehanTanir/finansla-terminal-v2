[global]
developmentMode = false

[server]
headless = true
port = 8501
address = "0.0.0.0"
enableCORS = false
enableXsrfProtection = false
maxUploadSize = 50
enableWebsocketCompression = true

[browser]
gatherUsageStats = false
serverAddress = "0.0.0.0"

[theme]
base = "dark"
primaryColor = "#ff6600"
backgroundColor = "#0a0a0a"
secondaryBackgroundColor = "#111111"
textColor = "#e8e8e8"
font = "monospace"

[client]
showErrorDetails = false
toolbarMode = "minimal"