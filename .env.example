# FINANSAL TERMINAL - Environment Variables
# Copy this file to .env and fill in values

# === REQUIRED ===
# API URL - where the FastAPI backend is running
# For local development:
API_URL=http://localhost:8000
# For Railway (replace with your actual Railway backend URL if deploying separately):
# API_URL=https://your-backend.up.railway.app

# === PORTS ===
API_PORT=8000
STREAMLIT_PORT=8501

# === OPTIONAL - IMPROVE DATA COVERAGE ===

# AISHub username (free registration at https://www.aishub.net)
# Without this, anonymous tier is used (limited data)
# AISHUB_USERNAME=your_username

# NewsAPI key (free at https://newsapi.org) - improves news coverage
# NEWSAPI_KEY=your_newsapi_key

# Alpha Vantage key (free at https://www.alphavantage.co) - backup financial data
# ALPHA_VANTAGE_KEY=your_key

# OpenWeather key (optional, for port weather data)
# OPENWEATHER_KEY=your_key